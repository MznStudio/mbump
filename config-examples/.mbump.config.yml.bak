# YML 配置文件示例（YAML 别名）
# 文件名: .mbump.config.yml.bak
# 特点: 与 .yaml 完全相同，只是扩展名不同

packagePaths:
  components: packages/components/package.json
  cli: packages/cli/package.json
  core: packages/core/package.json
  default: package.json

defaults:
  releaseType: patch
  dryRun: false
  verbose: false
  allowUncommitted: false
  npm: false

git:
  commitMessage: 'chore: bump version to {{newVersion}}'
  push: true
  autoCommit: true
  tag: true
  tagPrefix: v
  changelog: true

publish:
  command: npm publish
  skipChecks: false
